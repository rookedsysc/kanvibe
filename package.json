{
  "name": "kanvibe",
  "version": "0.1.0",
  "private": true,
  "main": "electron/background.js",
  "scripts": {
    "dev": "node scripts/build-main.mjs && concurrently --kill-others \"next dev --port 8888\" \"wait-on http://localhost:8888 && electron .\"",
    "build": "next build && node scripts/build-main.mjs",
    "pack": "pnpm build && electron-builder",
    "lint": "eslint",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "better-sqlite3",
      "cpu-features",
      "electron",
      "esbuild",
      "node-pty",
      "sharp",
      "ssh2",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "electron-serve": "^3.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "next": "16.1.6",
    "next-intl": "^4.8.2",
    "node-pty": "^1.1.0",
    "react": "19.2.3",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.3",
    "reflect-metadata": "^0.2.2",
    "ssh2": "^1.17.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ssh2": "^1.15.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
