{
  "name": "kanvibe",
  "version": "0.1.0",
  "private": true,
  "description": "AI agent task management Kanban board with embedded SQLite desktop packaging.",
  "author": "rookedsysc",
  "engines": {
    "node": "24.x"
  },
  "main": "electron/main.js",
  "scripts": {
    "predev": "node scripts/ensure-native-runtime.cjs --electron",
    "predb:prepare": "node scripts/ensure-native-runtime.cjs",
    "predesktop:dev": "node scripts/ensure-native-runtime.cjs --electron",
    "prestart": "node scripts/ensure-native-runtime.cjs --electron",
    "dev": "node scripts/run-desktop-dev.cjs",
    "build": "pnpm build:renderer && pnpm build:main",
    "build:renderer": "vite build",
    "build:main": "node scripts/build-desktop-main.cjs",
    "start": "node scripts/run-desktop-start.cjs",
    "desktop:dev": "node scripts/run-desktop-dev.cjs",
    "db:prepare": "tsx scripts/build-seed-db.ts",
    "rebuild:native:electron": "electron-rebuild -f --build-from-source --only better-sqlite3",
    "dist": "pnpm db:prepare && pnpm build && pnpm rebuild:native:electron && electron-builder --mac dmg zip",
    "dist:dir": "pnpm db:prepare && pnpm build && pnpm rebuild:native:electron && electron-builder --dir",
    "lint": "eslint",
    "check": "tsc --noEmit",
    "test:e2e:login": "bash -lc 'for port in 4884 4885; do fuser -k \"$port\"/tcp 2>/dev/null || true; done; rm -f .next/dev/lock; playwright test tests/e2e/login.spec.js'",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "cpu-features",
      "electron",
      "electron-winstaller",
      "esbuild",
      "node-pty",
      "sharp",
      "unrs-resolver",
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "next": "16.1.6",
    "next-intl": "^4.8.2",
    "node-pty": "^1.1.0",
    "react": "19.2.3",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.9.4",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.21.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "vite": "^7.1.10",
    "vitest": "^4.0.18"
  }
}
